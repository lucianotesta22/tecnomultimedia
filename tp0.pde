void setup(){
  size(800,600);
  background(0,100,120);
}

void draw(){
  noStroke();
  fill(0,100,0);
  rect(0,400,800,200);
  fill(255);
  ellipse(400,450,300,300);
  ellipse(400,300,200,200);
  fill(200,0,0);
  ellipse(400,235,140,65);
  fill(255);
  ellipse(400,170,150,150);
  stroke(2);
  fill(0);
  ellipse(400,115,150,40);
  rect(360,25,80,100);
  fill(0,0,150);
  ellipse(375,155,25,25);
  ellipse(430,155,25,25);
  fill(220,110,0);
  triangle(400,175,400,195,460,185);
  line(370,150,380,160);
  line(370,160,380,150);
  line(425,150,435,160);
  line(425,160,435,150);
  strokeWeight(4);
  line(375,210,385,215);
  line(385,215,420,215);
  line(420,215,430,210);
  line(340,300,240,240);
  line(240,240,220,220);
  line(240,240,240,220);
  line(460,300,560,240);
  line(560,240,580,220);
  line(560,240,560,220);
}
